### avoir la liste des campagnes par utilisateur
GET http://localhost:3000/campaigns
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiIzIiwidXNlcm5hbWUiOiJTeWx2YW5hcyIsImlhdCI6MTc3MzE0NTQxMiwiZXhwIjoxNzczMTUyNjEyfQ.qThYy2oEx_iRzQ3hq53kFQsvq2T522LjCerzLVVIQ4o
content-type: application/json

###
GET http://localhost:3000/campaigns/1/characters/me

### créer une campagne
POST http://localhost:3000/campaigns
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiIzIiwidXNlcm5hbWUiOiJTeWx2YW5hcyIsImlhdCI6MTc3MzE0NTQxMiwiZXhwIjoxNzczMTUyNjEyfQ.qThYy2oEx_iRzQ3hq53kFQsvq2T522LjCerzLVVIQ4o
content-type: application/json

{
  "camp_name": "La caravane de sombrelune",
  "mode": "campagne en ligne",
  "synopsis": "mouai"
}

### tentative avec un mauvais code invitation
POST http://localhost:3000/campaigns/join
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiIzIiwidXNlcm5hbWUiOiJTeWx2YW5hcyIsImlhdCI6MTc3MjIxMDUwMiwiZXhwIjoxNzcyMjE3NzAyfQ.lut3m6DN8CjdTNQYRPsVqkoJvNN9Ikk5vGS9c-O1ZaE
content-type: application/json

{
  "invite_code": "AAAAA"
}

### tentative avec un bon code invitation
POST http://localhost:3000/campaigns/join
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI0IiwidXNlcm5hbWUiOiJNYXgiLCJpYXQiOjE3NzMxNDcyMzAsImV4cCI6MTc3MzE1NDQzMH0.IKzWoKNNLjX9fwVSO54kgMYGnLnQSbfGfwOAjP7EpBc
content-type: application/json

{
  "invite_code": "OVKHW9U0"
}

